{
  "name": "@leros/desktop",
  "version": "0.1.14",
  "description": "Leros desktop application",
  "author": "insmtx",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/insmtx/Leros.git",
    "directory": "frontend/apps/desktop"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "compile": "electron-vite build",
    "build": "pnpm run compile",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "node scripts/dist-local.mjs",
    "dist:dir": "pnpm run compile && electron-builder --dir --publish never",
    "dist:mac:arm64": "pnpm run compile && electron-builder --mac --arm64 --publish never",
    "dist:mac:x64": "pnpm run compile && electron-builder --mac --x64 --publish never",
    "dist:win:x64": "pnpm run compile && electron-builder --win --x64 --publish never",
    "dist:linux:x64": "pnpm run compile && electron-builder --linux --x64 --publish never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "preview": "electron-vite preview",
    "lint": "biome check .",
    "test": "vitest run",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@leros/ui": "workspace:*",
    "@leros/store": "workspace:*",
    "@leros/app-ui": "workspace:*",
    "@leros/styles": "workspace:*",
    "electron-updater": "^6.6.2",
    "react-router-dom": "^7.6.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "lucide-react": "catalog:",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@leros/tsconfig": "workspace:*",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "^4",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^6.0.0-beta.1",
    "jsdom": "catalog:",
    "png-to-ico": "^2.1.8",
    "tailwindcss": "^4",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vite": "^8.0.0"
  }
}
